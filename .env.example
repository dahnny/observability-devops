# Copy this file to .env before running the stack.

# Alertmanager posts all alerts to this Slack incoming webhook.
# For offline local demos, leave unset and Alertmanager will use the local fallback URL.
SLACK_WEBHOOK_URL=

# GitHub Actions metrics source for the DORA exporter.
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=

# Grafana local admin credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
